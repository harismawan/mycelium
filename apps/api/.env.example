# API Server Environment Variables
DATABASE_URL=postgresql://mycelium:mycelium@localhost:5432/mycelium?schema=public
JWT_SECRET=mycelium-dev-secret-change-in-production
REDIS_URL=redis://localhost:6379
PORT=3000
NODE_ENV=development

# CORS origin — set to your frontend URL in production (e.g. https://mycelium.example.com)
# Defaults to allowing all origins when not set
# CORS_ORIGIN=http://localhost:5173
